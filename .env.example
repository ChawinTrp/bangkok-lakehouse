# Copy to .env (which is git-ignored) and adjust as needed.

# Storage backend: local (Parquet on disk now) | gcs (Phase 4)
STORAGE_BACKEND=local
LAKEHOUSE_ROOT=./data

# Traffy Fondue live API (verified 2026-06-16: supports limit/offset, ordered by
# last_activity DESC, NO server-side date filter, deep offsets 502)
TRAFFY_API_URL=https://publicapi.traffy.in.th/teamchadchart-stat-api/geojson/v1

# Airflow in Docker (used later). 50000 is a safe default on Windows.
AIRFLOW_UID=50000
